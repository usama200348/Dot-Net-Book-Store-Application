@{
    ViewData["Title"] = "Home Page";
}


<div class="my-4">
    <form class="row g-3">
        <!-- Genre Select -->
        <div class="col-md-4">
            <label class="form-label" for="genere">Genres</label>
            <select class="form-select" id="genere">
                <option selected>Choose...</option>
                <option value="1">Action</option>
                <option value="2">Horror</option>
                <option value="3">Comedy</option>
                <option value="4">Romance</option>
                <option value="5">Science Fiction</option>
            </select>
        </div>

        <!-- Search by Title -->
        <div class="col-md-6">
            <label class="form-label" for="bookTitle">Search By Title</label>
            <div class="input-group">
                <span class="input-group-text">📚</span>
                <input type="text" class="form-control" id="bookTitle" placeholder="Book Title">
            </div>
        </div>

        <!-- Submit Button -->
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </form>
</div>


<div class="w-100 mt-4 d-flex flex-wrap gap-2">
    @for (int i = 0; i <= 10; i++)
    {
        <div class="card mx-2 wb-2" style="width: 16rem;">
            <img src="..." class="card-img-top" alt="...">
            <div class="card-body">
                <h5 class="card-title">Book title</h5>
                <p class="card-text">Author : </p>
                <p class="card-text">Price : </p>
                <a href="#" class="btn btn-primary">Add To Cart</a>
            </div>
        </div>
    }
</div>